# Database
DATABASE_URL=postgresql://user:password@localhost:5432/ahc

# AI Services (Required for core features)
GROQ_API_KEY=gsk_your_groq_api_key_here

# AI Services (Required for RAG/Semantic Search)
OPENAI_API_KEY=sk-your_openai_key_here

# AI Services (Optional - for voice/video interviews)
HUME_API_KEY=your_hume_api_key
HUME_SECRET_KEY=your_hume_secret_key
TAVUS_API_KEY=your_tavus_api_key

# WhatsApp (Optional)
WHATSAPP_API_TOKEN=your_whatsapp_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id

# Email (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Application
NODE_ENV=development
PORT=5000

# Authentication (Required - change in production!)
JWT_SECRET=your-random-secret-key-change-in-production-min-32-chars
SESSION_SECRET=your-session-secret-key-change-in-production

# Admin API (Optional - for protected admin endpoints)
ADMIN_API_KEY=your-admin-api-key-for-protected-endpoints

# PNET API Integration (For AI Agents - South African Job Board)
PNET_API_BASE_URL=https://your-ats-domain.com/pnet-api
PNET_API_KEY=your-pnet-api-key-here
