# UiXpress Server Configuration
PORT=3000
SERVER_URL=http://localhost:3000
NODE_ENV=development

# WordPress Connection
WORDPRESS_URL=http://localhost/wordpress
WORDPRESS_USERNAME=admin
WORDPRESS_PASSWORD=your_application_password

# Database Configuration (PostgreSQL for Activity & Analytics)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=uixpress
DB_USER=postgres
DB_PASSWORD=

# JWT Configuration
JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=24h

# Analytics & Activity
ANALYTICS_ENABLED=true
ACTIVITY_LOG_ENABLED=true

# Security
TURNSTILE_SECRET_KEY=

# Updates
UPDATE_CHECK_URL=

# License
LICENSE_KEY=B5E0-B5F8-DD86-89E6-ACA4-9DD6-E6E1-A930
